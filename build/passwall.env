#
# aarch64_cortex-a53 只是软件包架构，不足以唯一确定 OpenWrt target/subtarget。
# 请把下面两个值改成你设备对应的平台配置。
#
# 常见示例：
# bcm27xx + bcm2710  -> Raspberry Pi 3 / 3B+
# bcm27xx + bcm2711  -> Raspberry Pi 4
# mvebu   + cortexa53 -> 部分 Marvell 64-bit 设备
#

TARGET_BOARD_DEFAULT=
TARGET_SUBTARGET_DEFAULT=
TARGET_PROFILE_DEFAULT=

# 默认编译的软件包，可按需增减。
PASSWALL_PACKAGES="luci-app-passwall luci-i18n-passwall-zh-cn xray-core"
